# Copier ce fichier en .env.local et renseigner les vraies valeurs.
# .env.local n'est jamais commité (voir .gitignore).

# Clé API-NBA (api-sports.io) — palier gratuit : 100 requêtes/jour.
# Créer un compte sur https://api-sports.io puis copier la clé du dashboard.
# Tant que cette variable est vide, l'app utilise les données de démonstration
# (src/lib/mock-data.ts) pour rester fonctionnelle en développement.
NBA_API_KEY=

# Stripe (à brancher lors de l'intégration des paiements — non utilisé pour l'instant)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
